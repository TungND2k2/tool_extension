{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "lib": ["ES2022"],
    "types": ["node", "vscode"],
    "sourceMap": true,
    "rootDir": "extension",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["extension/**/*.ts"],
  "exclude": ["node_modules", "out", "src"]
}
